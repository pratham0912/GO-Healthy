# ─────────────────────────────────────────────────────────────
# GO HEALTHY — Environment Variable Reference for Vercel Deployment
# Copy these keys into: Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Server (leave PORT blank on Vercel — it sets it automatically)
NODE_ENV=production

# MongoDB Atlas — replace with your Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/gohealthy?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_strong_random_secret_here
JWT_EXPIRES_IN=7d

# Google OAuth 2.0 (same as local)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# CORS — set to your Vercel deployment URL once you have it (e.g. https://go-healthy.vercel.app)
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email — Gmail App Password (16 chars, not your real password)
EMAIL_USER=gohealthy0912@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_RECEIVER=gohealthy0912@gmail.com
